<Window x:Class="WindowSorter.View.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="300" Width="500"
        Background="#EEE"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <Image Source="/icon/icon.ico" Width="64" Height="64" Margin="0,0,0,0" HorizontalAlignment="Center"/>
                <TextBlock x:Name="AppNameText" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>

            <TextBlock x:Name="VersionText" Margin="0,0,0,0"/>
            <TextBlock Text="Copyright(C) 2026 Lupinateria"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1">
            <Button Content="OK" Width="100" Height="30" Click="CloseButton_Click" HorizontalAlignment="Right" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
