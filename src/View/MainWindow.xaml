<Window x:Class="WindowSorter.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowSorter.View"
        xmlns:vm="clr-namespace:WindowSorter.ViewModel"
        xmlns:view="clr-namespace:WindowSorter.View"
        mc:Ignorable="d"
        Background="{DynamicResource WindowBackgroundBrush}"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        WindowStyle="None"
        Title="Window Sorter" Height="450" Width="800">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- スクロールバースタイル -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="{TemplateBinding Background}">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Background="{DynamicResource PrimaryTextBrush}" Opacity="0.3">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Margin="1,0" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainWindowVM/>
    </Window.DataContext>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="設定(_S)" Click="MenuSettings_Click" />
                <!--
                <Separator />
                <MenuItem Header="Window Sorter について(_A)" Click="MenuAbout_Click" />
                -->
            </ContextMenu>
        </Grid.ContextMenu>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 検索・選択情報領域 -->
        <Grid Grid.Row="0" Margin="20,15" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 検索ボックス -->
            <Border Grid.Column="0" Background="{DynamicResource SearchBoxBrush}" CornerRadius="4" Width="350" Padding="10,5">
                <TextBox x:Name="SearchTextBox" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent" 
                         Foreground="{DynamicResource PrimaryTextBrush}" 
                         BorderThickness="0" 
                         FontSize="16"
                         VerticalContentAlignment="Center" />
            </Border>

            <!-- 選択中のウィンドウタイトル表示ボックス -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0">
                <!-- <TextBlock Text="選択中: " Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0" /> -->
                <TextBlock Text="{Binding SelectedWindow.WindowTitle}" 
                               Foreground="{DynamicResource PrimaryTextBrush}" 
                               FontSize="16" 
                               VerticalAlignment="Center" 
                               TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding SelectedWindow.ProcessName, StringFormat='- {0}'}" 
                           Margin="10,0,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}" 
                           FontSize="16" 
                           VerticalAlignment="Center" 
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Grid>

        <!-- 区切り線 -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource SeparatorBrush}" Height="1" HorizontalAlignment="Stretch" Margin="20,0" />

        <!-- ウィンドウ表示領域 -->
        <!-- 全体はスクロールビュー -->
        <ScrollViewer Grid.Row="2" x:Name="MainScrollViewer" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="True" FocusVisualStyle="{x:Null}">

            <!-- ItemsControl ... 分類グループ -->
            <ItemsControl 
                x:Name="GroupList" 
                Margin="10"
                ItemsSource="{Binding WindowGroupList}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander IsExpanded="{Binding IsExpanded}" Margin="0,0,0,20">
                            <Expander.Header>
                                <!-- グループタイトル -->
                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="Bold" FontSize="18" Margin="0,0,0,5" />
                            </Expander.Header>

                            <!-- ItemsControl ... ウィンドウ一覧 -->
                            <ItemsControl ItemsSource="{Binding WindowList}">

                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="WindowItemBorder" Margin="5" Padding="2" CornerRadius="4" ClipToBounds="True"
                                                Width="{Binding WindowItemWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Cursor="Hand" MouseMove="WindowItem_MouseMove">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding TopMostCommand}" />
                                            </Border.InputBindings>

                                            <StackPanel>
                                                <Border Background="{DynamicResource TitleBarBackgroundBrush}" Padding="6,4" Height="40">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding WindowTitle}" Foreground="{DynamicResource PrimaryTextBrush}" TextWrapping="NoWrap" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding ProcessName}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,0,0,0" />
                                                    </StackPanel>
                                                </Border>

                                                <view:DwmThumbnailView SourceHandle="{Binding Handle}" 
                                                                       Width="{Binding ThumbnailWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Height="{Binding ThumbnailHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       ClippingElement="{Binding ElementName=MainScrollViewer}" />

                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
