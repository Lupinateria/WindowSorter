<Window x:Class="WindowSorter.View.Settings.SettingsMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:WindowSorter.View.Settings"
        xmlns:vm="clr-namespace:WindowSorter.ViewModel.Settings"
        xmlns:model_group="clr-namespace:WindowSorter.Model.Grouping"
        mc:Ignorable="d"
        Title="設定" Height="750" Width="950"
        WindowStartupLocation="CenterOwner"
        Background="#EEE"
        d:DataContext="{d:DesignInstance Type=vm:SettingsDataVM}">

    <Window.Resources>
        <!-- 真偽値 -> 表示/非表示 コンバーター -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- Enum値をComboBoxで表示するための設定 -->
        <ObjectDataProvider x:Key="TargetEnumValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="model_group:Target" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="OperatorEnumValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="model_group:Operator" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <!-- 全てのGroupBoxに共通の枠線色を適用 -->
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="BorderBrush" Value="#CCC" />
        </Style>
    </Window.Resources>
    
    <Window.DataContext>
        <vm:SettingsDataVM/>
    </Window.DataContext>
    
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 左側：メニューナビゲーション -->
        <Border Grid.Column="0" Grid.Row="0" BorderBrush="#AAA" BorderThickness="1,1,1,1" Margin="0,0,10,0" CornerRadius="0"  Background="#FFF">
            <ListBox x:Name="NavigationMenu" BorderThickness="0" Background="Transparent" SelectedIndex="0">
                <ListBoxItem x:Name="MenuGeneral" Content="全般" Padding="10,8" />
                <ListBoxItem x:Name="MenuGroup" Content="グループ設定" Padding="10,8" />
                <ListBoxItem x:Name="MenuRule" Content="ルール設定" Padding="10,8" />
            </ListBox>
        </Border>

        <!-- 右側：メイン編集エリア -->
        <Grid Grid.Column="1" Grid.Row="0">

            <!-- ******************************************************************** -->
            <!-- 全般設定 ビュー -->
            <!-- ******************************************************************** -->
            <StackPanel x:Name="GeneralSettingsView" Visibility="{Binding IsSelected, ElementName=MenuGeneral, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                <GroupBox Header="基本設定" Margin="0,0,0,10">
                    <StackPanel Margin="10">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ホットキー" VerticalAlignment="Center" Width="100" />
                            <TextBox Width="200" Height="25" Text="{Binding HotKeyText, Mode=OneWay}" IsReadOnly="True" 
                                     Background="#F5F5F5" VerticalContentAlignment="Center" Padding="5,0"
                                     PreviewKeyDown="HotKeyTextBox_PreviewKeyDown" Cursor="Arrow" />
                            <Button Content="クリア" Command="{Binding ClearHotKeyCommand}" Margin="10,0,0,0" Width="60" Height="25" />
                            <TextBlock Text="入力欄をクリックして、設定したいキーを押してください。" VerticalAlignment="Center"  FontSize="11" Margin="10,0,0,0" Foreground="#888" />
                        </StackPanel>


                        <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                            <TextBlock Text="サムネイル" VerticalAlignment="Center" Width="100" />
                            <TextBox Width="60" Height="25" Text="{Binding ThumbnailWidth}" VerticalContentAlignment="Center" Padding="5,0" />
                            <TextBlock Text="px" VerticalAlignment="Center" Margin="5,0,0,0" />
                            <TextBlock Text="×" VerticalAlignment="Center" Margin="10,0,10,0" />

                            <TextBox Width="60" Height="25" Text="{Binding ThumbnailHeight}" VerticalContentAlignment="Center" Padding="5,0" />
                            <TextBlock Text="px" VerticalAlignment="Center" Margin="5,0,0,0" />

                            <TextBlock Text="デフォルト: 284x160" VerticalAlignment="Center"  FontSize="11" Margin="10,0,0,0" Foreground="#888" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                            <TextBlock Text="検索方法" VerticalAlignment="Center" Width="100" />
                            <RadioButton Content="部分一致" 
                                         IsChecked="{Binding IsSearchPartialMatch}" 
                                         VerticalAlignment="Center" Margin="0,0,20,0" />
                            <RadioButton Content="あいまい" 
                                         IsChecked="{Binding IsSearchFuzzy}" 
                                         VerticalAlignment="Center" />
                        </StackPanel>
                        
                        <CheckBox Content="ウィンドウ選択後、検索テキストをクリアする" 
                                  IsChecked="{Binding ClearSearchOnWindowSelect}" 
                                  Margin="0,15,0,0" />


                    </StackPanel>
                </GroupBox>
                
                <GroupBox Header="高度な設定" Margin="0,0,0,0">
                    <StackPanel Margin="10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ウィンドウ表示の遅延時間" VerticalAlignment="Center" Margin="0,0,20,0" />
                            <TextBox Width="100" Height="25" Text="{Binding ShowWindowDelay}" 
                                     VerticalContentAlignment="Center" Padding="5,0" />
                            <TextBlock Text="ms" VerticalAlignment="Center" Margin="10,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="表示時の白いチラツキを軽減します。10ms程度を推奨。" FontSize="11" Margin="0,5,0,0" Foreground="#888" />
                    </StackPanel>
                </GroupBox>
                
            </StackPanel>

            <!-- ******************************************************************** -->
            <!-- グループ設定 ビュー -->
            <!-- ******************************************************************** -->
            <Grid x:Name="GroupSettingsView" Visibility="{Binding IsSelected, ElementName=MenuGroup, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Visible}">
                <Grid.RowDefinitions>
                    <!-- グループ一覧 -->
                    <RowDefinition Height="180" />
                    
                    <!-- 詳細編集エリア -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Header="グループ" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ListBox x:Name="GroupListBox" Margin="5" 
                                 ItemsSource="{Binding GroupList}" 
                                 SelectedItem="{Binding SelectedGroup}"
                                 DisplayMemberPath="Name" />
                        <StackPanel Grid.Column="1" Margin="5" VerticalAlignment="Top">
                            <Button Content="追加" Command="{Binding AddGroupCommand}" Width="60" Margin="0,0,0,5" />
                            <Button Content="削除" Command="{Binding RemoveGroupCommand}" CommandParameter="{Binding SelectedItem, ElementName=GroupListBox}" Width="60" Margin="0,0,0,5" />
                            <Button Content="↑" Command="{Binding MoveUpGroupCommand}" CommandParameter="{Binding SelectedItem, ElementName=GroupListBox}" Width="60" Margin="0,0,0,5" />
                            <Button Content="↓" Command="{Binding MoveDownGroupCommand}" CommandParameter="{Binding SelectedItem, ElementName=GroupListBox}" Width="60" Margin="0,0,0,5" />
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- 選択されたグループの詳細 -->
                <Grid Grid.Row="1" IsEnabled="{Binding SelectedGroup, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!-- グループ名 -->
                        <RowDefinition Height="*" />
                        <!-- ソートルール一覧 -->
                        <RowDefinition Height="*" />
                        <!-- 条件設定 -->
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                        <TextBlock Text="名前:" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBox Width="300" Text="{Binding SelectedGroup.Name, UpdateSourceTrigger=PropertyChanged}" Padding="3" />
                    </StackPanel>

                    <GroupBox Grid.Row="1" Header="並び替えルール" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ListBox x:Name="SortRuleListBox" Margin="5"
                                ItemsSource="{Binding SelectedGroup.SortRules}" 
                                SelectedItem="{Binding SelectedSortRule}"
                                DisplayMemberPath="Name" />
                            <StackPanel Grid.Column="1" Margin="5" VerticalAlignment="Top">
                                <Button Content="追加" Command="{Binding AddSortRuleCommand}" Width="60" Margin="0,0,0,5" />
                                <Button Content="削除" Command="{Binding RemoveSortRuleCommand}" CommandParameter="{Binding SelectedItem, ElementName=SortRuleListBox}" Width="60" Margin="0,0,0,5" />
                                <Button Content="↑" Command="{Binding MoveUpSortRuleCommand}" CommandParameter="{Binding SelectedItem, ElementName=SortRuleListBox}" Width="60" Margin="0,0,0,5" />
                                <Button Content="↓" Command="{Binding MoveDownSortRuleCommand}" CommandParameter="{Binding SelectedItem, ElementName=SortRuleListBox}" Width="60" Margin="0,0,0,5" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Row="2" Header="ルールの条件設定" IsEnabled="{Binding SelectedSortRule, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"></RowDefinition>
                                <RowDefinition Height="*"></RowDefinition>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,5,0,10">
                                <TextBlock Text="名前:" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBox Width="200" Text="{Binding SelectedSortRule.Name, UpdateSourceTrigger=PropertyChanged}" Padding="3" Margin="0,0,20,0" />

                                <TextBlock Text="評価方法:" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <ComboBox Width="150" SelectedValue="{Binding SelectedSortRule.EvalType}" SelectedValuePath="Tag">
                                    <ComboBoxItem Content="AND (全て一致)" Tag="{x:Static model_group:EvalType.AND}" />
                                    <ComboBoxItem Content="OR (いずれか一致)" Tag="{x:Static model_group:EvalType.OR}" />
                                </ComboBox>
                            </StackPanel>

                            <ListBox Grid.Row="1" Grid.Column="0" Margin="5" ItemsSource="{Binding SelectedSortRule.Conditions}" HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="対象:" VerticalAlignment="Center" Margin="0,0,5,0" />
                                            <ComboBox Grid.Column="1" Width="100" Margin="0,0,10,0" 
                                                ItemsSource="{Binding Source={StaticResource TargetEnumValues}}"
                                                SelectedItem="{Binding Target}" />

                                            <TextBlock Grid.Column="2" Text="方法:" VerticalAlignment="Center" Margin="0,0,5,0" />
                                            <ComboBox Grid.Column="3" Width="100" Margin="0,0,10,0" 
                                                ItemsSource="{Binding Source={StaticResource OperatorEnumValues}}"
                                                SelectedItem="{Binding Operator}" />

                                            <TextBox Grid.Column="4" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" Padding="2" />

                                            <Button Grid.Column="5" Content="削除" Width="40" 
                                                Command="{Binding DataContext.RemoveSortRuleConditionCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                CommandParameter="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                                <Button Content="追加" Command="{Binding AddSortRuleConditionCommand}" Width="60" Margin="0,0,0,5" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>
            </Grid>

            <!-- ******************************************************************** -->
            <!-- ルール設定ビュー -->
            <!-- ******************************************************************** -->
            <Grid x:Name="RuleSettingsView" Visibility="{Binding IsSelected, ElementName=MenuRule, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Visible}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="180" />
                    <!-- ルール一覧 -->
                    <RowDefinition Height="*" />
                    <!-- 詳細編集エリア -->
                </Grid.RowDefinitions>

                <GroupBox Header="ルール" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ListBox x:Name="RuleListBox" Margin="5" 
                                 ItemsSource="{Binding GroupingRuleList}" 
                                 SelectedItem="{Binding SelectedGroupingRule}"
                                 DisplayMemberPath="Name" />
                        <StackPanel Grid.Column="1" Margin="5" VerticalAlignment="Top">
                            <Button Content="追加" Command="{Binding AddGroupingRuleCommand}" Width="60" Margin="0,0,0,5" />
                            <Button Content="削除" Command="{Binding RemoveGroupingRuleCommand}" CommandParameter="{Binding SelectedItem, ElementName=RuleListBox}" Width="60" Margin="0,0,0,5" />
                            <Button Content="↑" Command="{Binding MoveUpGroupingRuleCommand}" CommandParameter="{Binding SelectedItem, ElementName=RuleListBox}" Width="60" Margin="0,0,0,5" />
                            <Button Content="↓" Command="{Binding MoveDownGroupingRuleCommand}" CommandParameter="{Binding SelectedItem, ElementName=RuleListBox}" Width="60" Margin="0,0,0,5" />
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- 選択されたルールの詳細 -->
                <Grid Grid.Row="1" IsEnabled="{Binding SelectedGroupingRule, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!-- 基本情報 -->
                        <RowDefinition Height="Auto" />
                        <!-- 評価方法 -->
                        <RowDefinition Height="*" />
                        <!-- 条件一覧 -->
                    </Grid.RowDefinitions>

                    <Grid Margin="0,5,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="名前:" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBox Grid.Column="1" Text="{Binding SelectedGroupingRule.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,20,0" Padding="3" />

                        <TextBlock Grid.Column="2" Text="移動先:" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <ComboBox Grid.Column="3" 
                                  ItemsSource="{Binding GroupOptions}" 
                                  DisplayMemberPath="Name" 
                                  SelectedValuePath="ID" 
                                  SelectedValue="{Binding SelectedGroupingRule.MoveTargetGroupID}" 
                                  Padding="3" />
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="評価方法:" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <ComboBox Width="150" SelectedValue="{Binding SelectedGroupingRule.EvalType}" SelectedValuePath="Tag">
                            <ComboBoxItem Content="AND (全て一致)" Tag="{x:Static model_group:EvalType.AND}" />
                            <ComboBoxItem Content="OR (いずれか一致)" Tag="{x:Static model_group:EvalType.OR}" />
                        </ComboBox>
                    </StackPanel>

                    <GroupBox Grid.Row="2" Header="条件">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ListBox Margin="5" ItemsSource="{Binding SelectedGroupingRule.Conditions}" HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="対象:" VerticalAlignment="Center" Margin="0,0,5,0" />
                                            <ComboBox Grid.Column="1" Width="100" Margin="0,0,10,0" 
                                                      ItemsSource="{Binding Source={StaticResource TargetEnumValues}}"
                                                      SelectedItem="{Binding Target}" />

                                            <TextBlock Grid.Column="2" Text="方法:" VerticalAlignment="Center" Margin="0,0,5,0" />
                                            <ComboBox Grid.Column="3" Width="100" Margin="0,0,10,0" 
                                                      ItemsSource="{Binding Source={StaticResource OperatorEnumValues}}"
                                                      SelectedItem="{Binding Operator}" />

                                            <TextBox Grid.Column="4" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" Padding="2" />

                                            <Button Grid.Column="5" Content="削除" Width="40" 
                                                    Command="{Binding DataContext.RemoveGroupingRuleConditionCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Column="1" Margin="5">
                                <Button Content="追加" Command="{Binding AddGroupingRuleConditionCommand}" Width="60" Margin="0,0,0,5" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>
            </Grid>
        </Grid>

        <!-- ******************************************************************** -->
        <!-- フッターボタン -->
        <!-- ******************************************************************** -->
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Command="{Binding SaveCommand}" Width="100" Height="30"  Margin="0,0,10,0" />
            <Button Content="キャンセル" Command="{Binding CancelCommand}" Width="100" Height="30"/>
        </StackPanel>
    </Grid>
</Window>
